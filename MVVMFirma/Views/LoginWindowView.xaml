<Window x:Class="MVVMFirma.Views.LoginWindowView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MVVMFirma.Views"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="800"
      Title="LoginWindow"
      WindowStartupLocation="CenterScreen"
      WindowState="Maximized">

    <Grid Background="#EFEDFF">
        
        <!-- CENTRAL WINDOW -->
        <Border Background="#00788C" 
              Width="300" Height="500"
              CornerRadius="10"
              Padding="20"
              BorderBrush="AliceBlue"
              VerticalAlignment="Center"
              HorizontalAlignment="Center">
                

                <Grid>
                <Grid.RowDefinitions>
                    <!-- logo -->
                    <RowDefinition Height="*"/> 
                    <!-- creditensials -->
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <!-- LOGO AREA -->
                <Border Grid.Row="0" 
                        Background="white" 
                        CornerRadius="10" 
                        Margin="0,0,0,10">

                    <Image Source="/Resources/BizConLogoV2.png"
                           Stretch="UniformToFill"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                    
                </Border>

                <!-- CREDENTIALS AREA -->
                <StackPanel Grid.Row="1" VerticalAlignment="Top">
                    
                    <Label Content="Username: "
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="White"/>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5" Height="25"/>

                    <Label Content="Password: "
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="White"/>
                    <PasswordBox Name="PasswordBox" Margin="0,0,0,10" Height="25"/>

                    <Button Content="Login" 
                            Style="{StaticResource MenuButtonStyle}"
                            Height="40" 
                            Command="{Binding LoginCommand}"
                            CommandParameter="{Binding ElementName=PasswordBox}"
                            Margin="0,0,0,5"/>
                    <Button Content="Forgot password"
                            Style="{StaticResource MenuButtonStyle}"
                            Height="40"
                            Command="{Binding ForgotPasswordCommand}"/>

                </StackPanel>
            </Grid>
        
        </Border>
    
    </Grid>
</Window>
