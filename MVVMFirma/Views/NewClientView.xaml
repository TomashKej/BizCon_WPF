<local:JedenViewBase x:Class="MVVMFirma.Views.NewClientView"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         xmlns:local="clr-namespace:MVVMFirma.Views"
         mc:Ignorable="d" 
         d:DesignHeight="300" d:DesignWidth="300">
    <Grid Background="White">
        <!--dwie kolumny i 6 wierszy-->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <Label Grid.Column="0" Grid.Row="0" Content="Client Name" Margin="0,8,0,8"/>
        <TextBox Grid.Column="1" Grid.Row="0" Margin="0,8,0,8" Text="{Binding Path=ClientName,UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

        <Label Grid.Column="0" Grid.Row="1" Content="Phone Number" Margin="0,8,0,8"/>
        <TextBox Grid.Column="1" Grid.Row="1" Margin="0,8,0,8" Text="{Binding Path=PhoneNumber,UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

        <Label Grid.Column="0" Grid.Row="2" Content="Email Address" Margin="0,8,0,8"/>
        <TextBox Grid.Column="1" Grid.Row="2" Margin="0,8,0,8" Text="{Binding Path=EmailAddress,UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

        <Label Grid.Column="0" Grid.Row="3" Content="Address ID" Margin="0,8,0,8"/>
        <ComboBox Grid.Column="1" Grid.Row="3" ItemsSource="{Binding Addresses}"
                  DisplayMemberPath="AddressId" SelectedValuePath="AddressId"
                  SelectedValue="{Binding SelectedAddressId, Mode=TwoWay, ValidatesOnDataErrors=True}"/>

        <Label Grid.Column="0" Grid.Row="4" Content="Client Type" Margin="0,8,0,8"/>
        <ComboBox Grid.Column="1" Grid.Row="4" ItemsSource="{Binding ClientTypes}"
                  DisplayMemberPath="ClientType1" SelectedValuePath="ClientTypeId"
                  SelectedValue="{Binding SelectedClientTypeId, Mode=TwoWay, ValidatesOnDataErrors=True}"/>

        <Label Grid.Column="0" Grid.Row="5" Content="Notes" Margin="0,8,0,8"/>
        <TextBox  Grid.Column="1" Grid.Row="5" Margin="0,8,0,8" Text="{Binding Path=Notes,UpdateSourceTrigger=PropertyChanged}"/>

    </Grid>
</local:JedenViewBase>
