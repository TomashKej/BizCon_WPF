<UserControl x:Class="MVVMFirma.Views.InventorySearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MVVMFirma.Views"
             mc:Ignorable="d" 
             d:DesignHeight="1000" d:DesignWidth="800">
    

    <Grid Background="GhostWhite">
        <Grid.RowDefinitions>
            <RowDefinition Height="33"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Content="Inventory Search" HorizontalContentAlignment="Center"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0" Content="Product :" Margin="3" HorizontalContentAlignment="Left" VerticalContentAlignment="Center"/>
            <ComboBox Grid.Column="1" Margin="3" 
                      ItemsSource="{Binding ProductsComboBoxItems}"
                      DisplayMemberPath="Value"
                      SelectedValuePath="Key"
                      SelectedValue="{Binding ProductId, Mode=TwoWay}"
                      />

            <Label Grid.Column="2" Content="Batch no :" Margin="3" VerticalContentAlignment="Center"/>
            <TextBox Grid.Column="3" Margin="3" Text="{Binding BatchNumber, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>
        
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0" Content="Client Name :" Margin="3" VerticalContentAlignment="Center"/>
            <TextBox Grid.Column="1" Margin="3" Text="{Binding ClientId, UpdateSourceTrigger=PropertyChanged}"/>

            <Label Grid.Column="2" Content="Sku no :" Margin="3" VerticalContentAlignment="Center"/>
            <TextBox Grid.Column="3" Margin="3" Text="{Binding SkuNumber, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0" Content="Site :" Margin="3" VerticalContentAlignment="Center"/>
            <ComboBox Grid.Column="1" Margin="3" 
                      ItemsSource="{Binding SitesComboBoxItems}"
                      DisplayMemberPath="Value"
                      SelectedValuePath="Key"
                      SelectedValue="{Binding SiteId, Mode=TwoWay}"/>

            <Label Grid.Column="2" Content="Aisle :" Margin="3" VerticalContentAlignment="Center"/>
            <TextBox Grid.Column="3" Margin="3" Text="{Binding AisleNumber, UpdateSourceTrigger=PropertyChanged}"/>

            <Label Grid.Column="4" Content="Location :" Margin="3" VerticalContentAlignment="Center"/>
            <TextBox Grid.Column="5" Margin="3" Text="{Binding LocationNumber, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Search Inventory" 
                    Style="{StaticResource MenuButtonStyle}"
                    Margin="5" Height="40" Width="150" 
                    Command="{Binding SearchInventoryCommand}"/>

            <Button Content="Clear Filters" 
                    Style="{StaticResource MenuButtonStyle}"
                    Margin="5" Height="40" Width="150" Background="#12D0E0"
                    Command="{Binding ClearFiltersCommand}"/>
        </StackPanel>
    
        <DataGrid Grid.Row="5" 
                  Margin="5" 
                  ItemsSource="{Binding InventoryList}" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*"/>
                <DataGridTextColumn Header="Batch" Binding="{Binding Batch}" Width="*"/>
                <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="*"/>
                <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="*"/>
                <DataGridTextColumn Header="Client" Binding="{Binding ClientName}" Width="*"/>
                <DataGridTextColumn Header="Aisle" Binding="{Binding AisleName}" Width="80"/>
                <DataGridTextColumn Header="Location" Binding="{Binding LocationName}" Width="150"/>
                <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="80" FontWeight="Bold"/>
                <DataGridTextColumn Header="Unit price" Binding="{Binding UnitPrice ,StringFormat=£{0:N2}}" Width="80" FontWeight="Bold"/>
                <DataGridTemplateColumn Header="Action" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                
                                <Button Content="Edit" 
                                        Margin="2" 
                                        Width="60"
                                        Command="{Binding DataContext.EditInventoryCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                                
                                <Button Content="Delete" 
                                        Margin="2" 
                                        Width="60"
                                        Background="Red"
                                        Foreground="White"
                                        Command="{Binding DataContext.DeleteInventoryCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                                
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <ScrollViewer Grid.Row="6"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <Border Background="WhiteSmoke" BorderBrush="LightGray" BorderThickness="1" Margin="5" Padding="10">
                <StackPanel>
                    <TextBlock Text="Edit Inventory Item" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Foreground="DarkSlateBlue"/>

                    <UniformGrid Columns="3">
                        <StackPanel Margin="5">
                            <Label Content="Product Name:"/>
                            <TextBox Text="{Binding SelectedInventory.ProductName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <Label Content="Batch:"/>
                            <TextBox Text="{Binding SelectedInventory.Batch, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <Label Content="SKU:"/>
                            <TextBox Text="{Binding SelectedInventory.Sku, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <Label Content="Quantity:"/>
                            <TextBox Text="{Binding SelectedInventory.Quantity, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <Label Content="Unit Price:"/>
                            <TextBox Text="{Binding SelectedInventory.UnitPrice, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"/>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <Label Content="Category:"/>
                            <ComboBox ItemsSource="{Binding CategoriesComboBoxItems}" 
                          DisplayMemberPath="Value" 
                          SelectedValuePath="Value" 
                          SelectedValue="{Binding SelectedInventory.CategoryName, Mode=TwoWay}"/>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <Label Content="Client:"/>
                            <ComboBox ItemsSource="{Binding ClientsComboBoxItems}" 
                          DisplayMemberPath="Value" 
                          SelectedValuePath="Value" 
                          SelectedValue="{Binding SelectedInventory.ClientName, Mode=TwoWay}"/>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <Label Content="Site:"/>
                            <ComboBox ItemsSource="{Binding SitesComboBoxItems}" 
                          DisplayMemberPath="Value" 
                          SelectedValuePath="Value" 
                          SelectedValue="{Binding SelectedInventory.SiteName, Mode=TwoWay}"/>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <Label Content="Aisle:"/>
                            <ComboBox ItemsSource="{Binding AislesComboBoxItems}" 
                          DisplayMemberPath="Value" 
                          SelectedValuePath="Value" 
                          SelectedValue="{Binding SelectedInventory.AisleName, Mode=TwoWay}"/>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <Label Content="Location:"/>
                            <ComboBox ItemsSource="{Binding LocationsComboBoxItems}" 
                          DisplayMemberPath="Value" 
                          SelectedValuePath="Value" 
                          SelectedValue="{Binding SelectedInventory.LocationName, Mode=TwoWay}"/>
                        </StackPanel>
                    </UniformGrid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Save Changes" 
                            Command="{Binding SaveCommand}" 
                            Style="{StaticResource MenuButtonStyle}"
                            Margin="5" Height="40" Width="150" 
                            Background="ForestGreen"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>

    </Grid>
</UserControl>
